class Solution:
    def minAbsDiff(self, grid, k):
        m = len(grid)
        n = len(grid[0])
        answer = []

        for top in range(m - k + 1):
            row = []

            for left in range(n - k + 1):
                values = set()

                for r in range(top, top + k):
                    for c in range(left, left + k):
                        values.add(grid[r][c])

                values = sorted(values)

                if len(values) == 1:
                    row.append(0)
                else:
                    minimum_difference = float("inf")

                    for i in range(1, len(values)):
                        minimum_difference = min(
                            minimum_difference,
                            values[i] - values[i - 1]
                        )

                    row.append(minimum_difference)

            answer.append(row)

        return answer
