class Solution {
public:
    bool hasAllCodes(string s, int k) {
        if (s.size() < k) return false;

        unordered_set<int> seen;
        int value = 0;
        int mask = (1 << k) - 1;

        for (int i = 0; i < s.size(); i++) {
            value = ((value << 1) & mask) | (s[i] - '0');

            if (i >= k - 1) {
                seen.insert(value);
            }
        }

        return seen.size() == (1 << k);
    }
};
